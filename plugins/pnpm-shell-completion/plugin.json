{
  "name": "pnpm-fish-shell-completion",
  "version": "0.0.1",
  "description": "Provides tab completion for the fish shell",
  "packages": ["pnpm-shell-completion@latest"],
  "shell": {
    "init_hook": "set -ax fish_complete_path {{ .Virtenv }}"
  },
  "create_files": {
    "{{ .Virtenv }}/pnpm.fish": "./pnpm.fish" 
  }
}
